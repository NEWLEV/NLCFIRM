# ════════════════════════════════════════════
# NLCFirm Production Environment Configuration
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ════════════════════════════════════════════

# ─── Server ──────────────────────────────────
PORT=3000
NODE_ENV=production
# Must be set to your production domain for sitemap.xml and robots.txt
BASE_URL=https://nlcfirm.com

# ─── Security ────────────────────────────────
# REQUIRED: Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ─── Admin Seed Accounts ─────────────────────
# These passwords are only used when seeding the DB for the first time.
# Change immediately after first login. Must be at least 12 chars.
ADMIN_EMAIL=admin@nlcfirm.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_IMMEDIATELY_ON_FIRST_LOGIN
ADMIN2_DEFAULT_PASSWORD=CHANGE_ME_IMMEDIATELY_ON_FIRST_LOGIN

# ─── Email (SMTP) ────────────────────────────
# Recommended: Use a transactional provider (SendGrid, AWS SES, Mailgun)
# SendGrid example:
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
SMTP_FROM="New Level Consultants <info@nlcfirm.com>"

# ─── PayPal ──────────────────────────────────
# Get from: https://developer.paypal.com/dashboard/
# Use sandbox client ID for testing, live client ID for production
PAYPAL_CLIENT_ID=your_paypal_live_client_id_here
# PAYPAL_CLIENT_SECRET is used for server-side order verification (not exposed to frontend)
PAYPAL_CLIENT_SECRET=your_paypal_live_client_secret_here
